FROM golang:1.25.1

ARG app_name
ARG build_number
ARG version
ENV env_build_number=${build_number}
ENV env_version=${version}
ENV GO111MODULE=on
ENV ADDR=0.0.0.0
ENV TZ=Asia/Bangkok

RUN mkdir -p /go/src/github.com/IT-CP25-US1-School-Management-System/sms-data-service
WORKDIR /go/src/github.com/IT-CP25-US1-School-Management-System/sms-data-service

# Move to project folder
WORKDIR /go/src/github.com/IT-CP25-US1-School-Management-System/sms-data-service

COPY . . 
RUN go install github.com/githubnemo/CompileDaemon@latest
RUN go mod tidy     

RUN  go build -o  /go/src/github.com/IT-CP25-US1-School-Management-System/sms-data-service/tmp/app main.go

EXPOSE 3000
EXPOSE 3100

ENTRYPOINT CompileDaemon -include=go.mod -log-prefix=false -color=true -build="go build -o ./tmp/app main.go" -command="./tmp/app" 
